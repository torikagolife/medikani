/**
 * 【作戦A】外部（Workers）からのパスワード変更リクエストを受け取る
 * 1. スプレッドシートを更新
 * 2. その直後にCloudflare KVを更新（個別更新）
 */
function doPost(e) {
  try {
    const params = JSON.parse(e.postData.contents);
    const targetId = params.facilityId; // 施設ID
    
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    const masterSheet = ss.getSheetByName("顧客マスタ");
    
    // AA列(27列目)が存在しない場合は自動で列を追加する
    if (masterSheet.getMaxColumns() < 27) {
      masterSheet.insertColumnsAfter(masterSheet.getMaxColumns(), 27 - masterSheet.getMaxColumns());
    }

    const data = masterSheet.getDataRange().getValues();
    
    let targetRow = -1;
    
    // 1. スプレッドシートの対象行を探す
    for (let i = 1; i < data.length; i++) {
      // 🔥 修正: 施設IDは「I列」なのでインデックスは「8」
      if (String(data[i][8]).trim() === targetId) {
        targetRow = i + 1;
        break;
      }
    }
    
    if (targetRow === -1) {
      return ContentService.createTextOutput(JSON.stringify({ success: false, message: "IDが見つかりません" })).setMimeType(ContentService.MimeType.JSON);
    }
    
    let successKV = true;

    // 2. スプレッドシートとKVを更新（リクエストに含まれるものを処理）
    
    // 管理者パスワードの更新
    if (params.newPassword !== undefined) {
      masterSheet.getRange(targetRow, 25).setValue(params.newPassword); // Y列は25番目
      successKV = updateSingleKV(`${targetId}_pwd`, params.newPassword);
    }
    
    // ユーザーパスワードの更新
    if (params.newUserPassword !== undefined) {
      masterSheet.getRange(targetRow, 27).setValue(params.newUserPassword); // AA列は27番目
      successKV = updateSingleKV(`${targetId}_userpwd`, params.newUserPassword);
    }
    
    return ContentService.createTextOutput(JSON.stringify({ 
      success: successKV, 
      message: successKV ? "更新完了" : "KV更新失敗" 
    })).setMimeType(ContentService.MimeType.JSON);

  } catch (err) {
    // GASがクラッシュしても絶対にJSONでエラーを返す（Worker側に生々しいエラーを届ける）
    return ContentService.createTextOutput(JSON.stringify({ 
      success: false, 
      message: "GAS側例外: " + err.message + " / " + err.stack
    })).setMimeType(ContentService.MimeType.JSON);
  }
}

/**
 * Cloudflare KVへ特定のキーだけを個別に更新するヘルパー関数
 */
function updateSingleKV(key, value) {
  const props = PropertiesService.getScriptProperties();
  const CF_ACCOUNT_ID = props.getProperty('CF_ACCOUNT_ID');
  const CF_KV_NAMESPACE_ID = props.getProperty('CF_KV_NAMESPACE_ID');
  const CF_API_TOKEN = props.getProperty('CF_API_TOKEN');
  
  const url = `https://api.cloudflare.com/client/v4/accounts/${CF_ACCOUNT_ID}/storage/kv/namespaces/${CF_KV_NAMESPACE_ID}/values/${key}`;
  
  let options = {
    headers: { 'Authorization': `Bearer ${CF_API_TOKEN}` },
    muteHttpExceptions: true
  };

  // 値が空文字（パスワード解除）の時は PUT ではなく DELETE を使う
  if (value === "") {
    options.method = 'delete';
  } else {
    options.method = 'put';
    options.payload = value;
  }
  
  const response = UrlFetchApp.fetch(url, options);
  return response.getResponseCode() === 200;
}

/**
 * スプレッドシートのデータをCloudflare KVに一括同期する（既存機能の強化版）
 */
function syncAllSheetsToKV() {
  const props = PropertiesService.getScriptProperties();
  const CF_ACCOUNT_ID = props.getProperty('CF_ACCOUNT_ID');
  const CF_KV_NAMESPACE_ID = props.getProperty('CF_KV_NAMESPACE_ID');
  const CF_API_TOKEN = props.getProperty('CF_API_TOKEN');

  if (!CF_ACCOUNT_ID || !CF_KV_NAMESPACE_ID || !CF_API_TOKEN) {
    Browser.msgBox("エラー: スクリプトプロパティに設定が見つかりません。");
    return;
  }

  const ss = SpreadsheetApp.getActiveSpreadsheet();

  // --- ① 設定と準備 ---
  const targetConfigs = [
    ["内服同期", "[内]"],
    ["注射同期", "[注]"],
    ["外用同期", "[外]"]
  ];

  const baseUrl = `https://api.cloudflare.com/client/v4/accounts/${CF_ACCOUNT_ID}/storage/kv/namespaces/${CF_KV_NAMESPACE_ID}`;
  const headers = { 
    'Authorization': `Bearer ${CF_API_TOKEN}`,
    'Content-Type': 'application/json'
  };

  const allBody = [];
  const compIndex = {}; 
  const keySet = new Set();

  // --- ② 同期データの作成 ---
  for (const [sheetName, label] of targetConfigs) {
    const sheet = ss.getSheetByName(sheetName);
    if (!sheet) continue;

    const data = sheet.getDataRange().getValues();
    if (data.length < 2) continue;

    for (let i = 1; i < data.length; i++) {
      const row = data[i];
      // ★修正箇所: A列（ユーザーがスプレッドシートで作ったフルネームキー）を直接取得する
      const sheetKey = String(row[0] || "").trim(); 
      const csvValue = String(row[1] || "").trim();
      
      // A列のキーか、B列のデータが空ならスキップ
      if (!csvValue || !sheetKey) continue;

      const parts = csvValue.split(",");
      if (parts.length < 3) continue;

      // COMP_ 用にYJコードだけは一番最後から取得する
      const yjCode = parts[parts.length - 1].trim();

      // ★修正箇所: スプレッドシートのA列のキーに [内] などのラベルを付けて最終キーにする
      // 例: "[注]" + "複方オキシコドン注射液_8119500A1015"
      const key = `${label}${sheetKey}`;
      
      if (keySet.has(key)) continue;
      keySet.add(key);
      allBody.push({ key: key, value: csvValue.replace(/,/g, "，") });

      if (yjCode.length >= 7) {
        const baseCode = yjCode.substring(0, 7);
        const compKey = `COMP_${baseCode}`;
        if (!compIndex[compKey]) compIndex[compKey] = [];
        compIndex[compKey].push(key);
      }
    }
  }

  for (const compKey in compIndex) {
    allBody.push({ key: compKey, value: JSON.stringify(compIndex[compKey]) });
  }

  // --- ②-2 顧客マスタ（施設名・パスワード・StripeID）の同期 ---
  const customerSheet = ss.getSheetByName("顧客マスタ");
  if (customerSheet) {
    const cData = customerSheet.getDataRange().getValues();
    for (let i = 1; i < cData.length; i++) {
      const row = cData[i];
      const hId = String(row[8] || "").trim();    // I列: 施設ID
      
      const hName = String(row[7] || "").trim();  // H列: 施設名
      const stripeId = String(row[23] || "").trim(); // ★追加: X列 StripeID
      const hPwd = String(row[24] || "").trim();  // Y列: 管理者パスワード
      const hUserPwd = String(row[26] || "").trim(); // AA列: ユーザー用パスワード

      if (hId && hName) {
        allBody.push({ key: `${hId}_name`, value: hName });
      }
      if (hId && stripeId) {
        allBody.push({ key: `${hId}_stripe_id`, value: stripeId }); // ★追加
      }
      if (hId && hPwd) {
        allBody.push({ key: `${hId}_pwd`, value: hPwd });
      }
      if (hId && hUserPwd) {
        allBody.push({ key: `${hId}_userpwd`, value: hUserPwd });
      }
    }
  }

  if (allBody.length === 0) {
    Browser.msgBox("同期対象のデータが見つかりませんでした。");
    return;
  }

  // --- ③ Cloudflareへ一括送信 ---
  const chunkSize = 2000;
  let successCount = 0;
  
  for (let i = 0; i < allBody.length; i += chunkSize) {
    const chunk = allBody.slice(i, i + chunkSize);
    try {
      const response = UrlFetchApp.fetch(`${baseUrl}/bulk`, {
        method: 'put', 
        headers: headers,
        payload: JSON.stringify(chunk), 
        muteHttpExceptions: true
      });
      
      const resCode = response.getResponseCode();
      if (resCode === 200) {
        const resJson = JSON.parse(response.getContentText());
        if (resJson.success) {
          successCount += chunk.filter(item => !item.key.includes("COMP_")).length;
        }
      }
      Utilities.sleep(500); 
    } catch (e) {
      Logger.log("送信中に例外発生: " + e.toString());
    }
  }
  
  Browser.msgBox(`【マスターデータ 同期完了】\n\n${successCount} 件のデータを更新しました。`);
}

/**
 * 🌟 マニュアルシートの編集を監視（C2:メール送信 / F2:お知らせ更新）
 */
function onManualEdit(e) {
  const ss = e.source;
  const sheet = ss.getActiveSheet();
  const range = e.range;

  if (sheet.getName() !== "マニュアル") return;

  const addr = range.getA1Notation();
  
  // --- メール送信トリガー (C2) ---
  if (addr === "C2" && range.getValue() === "送信") {
    sendBulkEmailsFromMaster();
    range.clearContent();
  }

  // --- 運営からのお知らせ更新トリガー (F2) 🌟追加 ---
  if (addr === "F2" && range.getValue() === "更新") {
    const infoText = sheet.getRange("E2").getValue();
    const success = updateSingleKV("GLOBAL_INFO", infoText);
    
    if (success) {
      SpreadsheetApp.getActiveSpreadsheet().toast("アプリのお知らせを更新したカニ！🦀", "更新完了");
      range.clearContent();
    } else {
      SpreadsheetApp.getUi().alert("KVの更新に失敗しました。プロパティ設定を確認してくださいカニ🦀");
    }
  }
}

/**
 * 📧 顧客マスタから対象を抽出してメールを送る心臓部
 */
function sendBulkEmailsFromMaster() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const manualSheet = ss.getSheetByName("マニュアル");
  const masterSheet = ss.getSheetByName("顧客マスタ");

  // マニュアルシートから設定を読み込む
  const targetStatus = manualSheet.getRange("A2").getValue(); // A2: 送信対象のステータス
  const mailBody = manualSheet.getRange("B2").getValue();    // B2: 本文
  const signature = manualSheet.getRange("D2").getValue();   // D2: 署名
  
  // 署名を合体させる
  const fullBody = mailBody + "\n\n--\n" + signature;
  
  // 顧客マスタのデータを取得
  const data = masterSheet.getDataRange().getValues();
  
  // 🌟重要: 顧客マスタの「メールアドレス」が何列目か指定してください
  // 現在 I列が施設ID(8) なので、とりあえず J列(9) と仮定しています。適宜直してください。
  const EMAIL_COL = 19; 
  const STATUS_COL = 1; // B列: ステータス (0始まりで1)

  let count = 0;
  
  for (let i = 1; i < data.length; i++) {
    const row = data[i];
    const status = String(row[STATUS_COL]).trim();
    const email = String(row[EMAIL_COL]).trim();

    // ステータスが一致し、かつメールアドレスが入っている場合のみ送信
    if (status === targetStatus && email !== "") {
      try {
        GmailApp.sendEmail(email, "【メディカニ】運営からのお知らせ", fullBody, {
          from: "info@medikani.com", // 🌟info@medikani.comをエイリアス登録している必要あり
          name: "メディカニ運営事務局"
        });
        count++;
      } catch (err) {
        Logger.log("送信失敗: " + email + " / " + err.message);
      }
    }
  }

  // 完了報告（管理者にだけわかるように右下に通知を出す）
  SpreadsheetApp.getActiveSpreadsheet().toast(count + " 件の送信が完了したカニ！🦀", "メール送信完了");
}
