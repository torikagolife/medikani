  const adminSubject = `【紹介キャンペーン】${referrerName}様よりご紹介がありました`;
  let adminBody = `紹介キャンペーンフォームから新規投稿がありました。\n\n`;
  adminBody += `【紹介元】\nお名前: ${referrerName} 様\n施設: ${referrerFacility}\nメール: ${referrerEmail}\n\n`;
  adminBody += `【紹介先】\n施設: ${refereeFacility}\n担当者: ${refereeName} 様\nメール: ${refereeEmail}\n\n`;
  adminBody += `備考:\n${message}`;

  // 7. 送信実行
  sendEmailWithResend(RESEND_API_KEY, FROM_EMAIL, refereeEmail, refereeSubject, refereeBody);
  sendEmailWithResend(RESEND_API_KEY, FROM_EMAIL, referrerEmail, referrerSubject, referrerBody);
  sendEmailWithResend(RESEND_API_KEY, FROM_EMAIL, "toriweb@gmail.com", adminSubject, adminBody);
}

/**
 * Resend APIを使用してメールを送信するヘルパー関数
 */
function sendEmailWithResend(apiKey, from, to, subject, textBody) {
  const url = "https://api.resend.com/emails";
  const payload = { "from": from, "to": to, "subject": subject, "text": textBody };
  const options = {
    "method": "post",
    "contentType": "application/json",
    "headers": { "Authorization": "Bearer " + apiKey },
    "payload": JSON.stringify(payload),
    "muteHttpExceptions": true
  };
  const response = UrlFetchApp.fetch(url, options);
  Logger.log(response.getContentText());
}
